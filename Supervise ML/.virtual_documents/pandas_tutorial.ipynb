# Merging & Joining Data

df_custormers = pd.DataFrame({
    "customer_id": [1,2,3,4],
    "name": ["Adam", "Bob", "Carlie", "Dave"]
})

df_orders = pd.DataFrame({
    "order_id": [1,2,3,4],
    "customer_id": [2,1,4,5],
    "amount":[250,120,300,180]
})

pd.merge(df_custormers, df_orders, on="customer_id") # inner join 
pd.merge(df_custormers, df_orders, on="customer_id", how="left") #left join
pd.merge(df_custormers, df_orders, on="customer_id", how="right") # right join
pd.merge(df_custormers, df_orders, on="customer_id", how="outer") # outer join



df_custormers


df_orders


# Concatenation 

